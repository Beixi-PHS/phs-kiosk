# PHS Kiosk — Environment Variables
# Set ALL of these in Render.com → Environment tab

# ── Microsoft Azure App Registration ─────────────────────────────────────────
# From portal.azure.com → Azure Active Directory → App Registrations

# Application (Client) ID — Overview page
AZURE_CLIENT_ID=your_client_id_here

# Directory (Tenant) ID — Overview page
AZURE_TENANT_ID=your_tenant_id_here

# Client Secret — Certificates & Secrets (copy immediately, shown once only)
AZURE_CLIENT_SECRET=your_client_secret_here

# ── OneDrive Excel File ───────────────────────────────────────────────────────
# Email of the Microsoft 365 account that owns the OneDrive file
ONEDRIVE_USER_ID=yourname@yourdomain.com

# File ID of PHS_Feedback.xlsx in OneDrive
# To find: open the file → Share → Copy Link
# Extract the long string after /items/ in the URL
ONEDRIVE_FILE_ID=your_file_id_here

# Worksheet name inside the Excel file
WORKSHEET_NAME=Feedback Responses

# ── Dashboard password ────────────────────────────────────────────────────────
DOWNLOAD_SECRET=phs2026
